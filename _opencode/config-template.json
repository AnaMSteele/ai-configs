{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "~/.agents/SOUL.md",
    "~/code/ai-configs/APPEND_SYSTEM.md"
  ],
  "model": "openai/gpt-5.5",
  "mcp": {
    "chrome-devtools": {
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": true,
      "type": "local"
    },
    "exa": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?exaApiKey=YOUR_EXA_API_KEY"
    },
    "exa-code": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?exaApiKey=YOUR_EXA_API_KEY&tools=get_code_context_exa"
    },
    "macuse": {
      "command": ["/Applications/Macuse.app/Contents/MacOS/macuse", "mcp"],
      "enabled": true,
      "type": "local"
    },
    "playwright": {
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": false,
      "type": "local"
    },
    "sentry": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp/nodaste/javascript-nextjs"
    }
  },
  "permission": "allow",
  "plugin": ["@tarquinen/opencode-dcp@latest", "opencode-pty@latest"],
  "provider": {
    "fireworks-ai": {
      "models": {
        "accounts/fireworks/models/glm-5": {
          "variants": {
            "thinking": {
              "clear_thinking": false,
              "description": "Deep reasoning with Preserved Thinking",
              "reasoningEffort": "high"
            }
          }
        },
        "accounts/fireworks/models/kimi-k2p5": {
          "name": "Kimi-K2.5",
          "variants": {
            "high": {
              "reasoningEffort": "high"
            },
            "low": {
              "reasoningEffort": "low"
            },
            "medium": {
              "reasoningEffort": "medium"
            }
          }
        }
      }
    },
    "synthetic": {
      "models": {
        "hf:moonshotai/Kimi-K2.5": {
          "name": "Kimi-K2.5",
          "variants": {
            "high": {
              "description": "Deep reasoning with Preserved Thinking",
              "reasoningEffort": "high"
            },
            "low": {
              "description": "Low Reasoning",
              "reasoningEffort": "low"
            },
            "medium": {
              "description": "Deep reasoning with Preserved Thinking",
              "reasoningEffort": "medium"
            }
          }
        },
        "hf:nvidia/Kimi-K2.5-NVFP4": {
          "name": "Kimi-K2.5-NVFP4",
          "variants": {
            "high": {
              "description": "Deep reasoning with Preserved Thinking",
              "reasoningEffort": "high"
            },
            "low": {
              "description": "Low Reasoning",
              "reasoningEffort": "low"
            },
            "medium": {
              "description": "Deep reasoning with Preserved Thinking",
              "reasoningEffort": "medium"
            }
          }
        },
        "hf:zai-org/GLM-4.7": {
          "variants": {
            "thinking": {
              "clear_thinking": false,
              "description": "Deep reasoning with Preserved Thinking",
              "reasoningEffort": "high"
            }
          }
        }
      }
    }
  },
  "server": {
    "hostname": "127.0.0.1",
    "port": 63333
  }
}
